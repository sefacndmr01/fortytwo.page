# SMTP — works with any provider (Gmail, Outlook, Zoho, self-hosted, etc.)
# Gmail: host=smtp.gmail.com, port=587, user=you@gmail.com, pass=app-password
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-password
SMTP_FROM=Fortytwo <noreply@fortytwo.page>
SMTP_TO=info@fortytwo.page
